# Blood Donation Platform - Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/blood_donation

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-here

# Admin Registration Secret
ADMIN_SECRET_KEY=your-admin-secret-key-here

# Email Configuration (Optional - for notifications)
# Leave these empty to skip email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM="Blood Donation Platform" <your-email@gmail.com>

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Server Configuration
PORT=5000
NODE_ENV=development
